# EduForge — Environment Variables Template
# Copy to .env and fill in your values
# Never commit .env to git!

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# CHANGE THIS in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-please-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://eduforge:eduforge@localhost:5432/eduforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Models ────────────────────────────────────────────────────────────────────
# CPU-optimised defaults — change to larger models if you add GPU
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GENERATION_MODEL=google/flan-t5-small

# ── Ingestion ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_FILE_SIZE_MB=50

# ── Generation ────────────────────────────────────────────────────────────────
GENERATION_TEMPERATURE=0.7
GENERATION_TOP_P=0.9
DEFAULT_EXAM_QUESTIONS=10
MAX_EXAM_QUESTIONS=50

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_EXPIRY_MINUTES=60
RATE_LIMIT_PER_MINUTE=60

# ── Monitoring ────────────────────────────────────────────────────────────────
# GRAFANA_PASSWORD=admin  # set in docker compose
